---
import { skills } from '../data/skills'

const uxSkills = skills.filter(s => s.group === 'ux')
const toolSkills = skills.filter(s => s.group === 'tools')
---
<section class="space-y-12">
  <div>
    <h3 class="font-serif text-xl font-semibold mb-5">UX Skills</h3>
    <ul class="grid grid-cols-2 gap-2">
      {uxSkills.map(s => (
        <li class="text-sm text-[#2C363F]">— {s.label}</li>
      ))}
    </ul>
  </div>
  <div>
    <h3 class="font-serif text-xl font-semibold mb-5">Tools</h3>
    <ul class="grid grid-cols-2 gap-2">
      {toolSkills.map(s => (
        <li class="text-sm text-[#2C363F]">— {s.label}</li>
      ))}
    </ul>
  </div>
</section>
