---
import { url } from '../utils/url'
---
<style>
  @keyframes blink {
    0%, 88%, 100% { transform: scaleY(1); }
    92%           { transform: scaleY(0.12); }
    96%           { transform: scaleY(1); }
  }
  .blink-face {
    display: inline-block;
    animation: blink 3.5s infinite;
    transform-origin: center 60%;
  }
</style>
<section class="max-w-5xl mx-auto px-6 pt-20 pb-24 text-center">
  <div class="w-full">
    <h1 class="font-serif text-5xl sm:text-6xl font-semibold leading-tight mb-5">
      Hi, I'm <span class="text-[#E16F7C]">Babi</span>. <span class="blink-face">ツ</span>
    </h1>
    <p class="text-xl text-[#3a3a3a] leading-relaxed mb-8 w-[90%] mx-auto">
      A Product Designer and Front-End Developer based in Montreal, building digital products that feel as good as they look — and hold up in the code.
    </p>

    <p class="text-base text-[#2C363F] leading-loose mb-10 w-[82%] mx-auto">
      I've spent the last 10+ years moving between two worlds that too often stay apart: strategic UX research and product design on one side, pixel-perfect front-end development on the other. Today, I bring them together to ship interfaces that are thoughtful to use and easy to maintain.
    </p>

    <div class="grid sm:grid-cols-3 gap-6 mb-12 border-t border-[#e0ddd8] pt-10">
      <div>
        <h2 class="font-semibold uppercase tracking-widest text-[#E16F7C] mb-2" style="font-size: 1rem;">Product Design</h2>
        <p class="text-sm text-[#2C363F] leading-relaxed">User research, prototyping, and scalable design systems in Figma — with a developer's mindset built in from the start.</p>
      </div>
      <div>
        <h2 class="font-semibold uppercase tracking-widest text-[#E16F7C] mb-2" style="font-size: 1rem;">Front-End Development</h2>
        <p class="text-sm text-[#2C363F] leading-relaxed">Responsive, pixel-perfect interfaces in HTML, CSS, and JavaScript with a strong focus on WCAG accessibility.</p>
      </div>
      <div>
        <h2 class="font-semibold uppercase tracking-widest text-[#E16F7C] mb-2" style="font-size: 1rem;">End-to-end delivery</h2>
        <p class="text-sm text-[#2C363F] leading-relaxed">With AI in my workflow, I take a product from Figma to working code on my own — keeping design intent intact.</p>
      </div>
    </div>

    <div class="flex gap-4 flex-wrap items-center justify-center">
      <a
        href={url('work')}
        class="px-6 py-3 bg-[#1a1a1a] text-white text-sm font-medium tracking-wide hover:bg-[#333] transition-colors"
      >
        see projects
      </a>
      <a
        href="mailto:bacarolina.g@gmail.com"
        class="group flex items-center gap-2 px-6 py-3 border border-[#1a1a1a] text-sm font-medium tracking-wide hover:bg-[#1a1a1a] hover:text-white transition-colors"
      >
        Get in touch
        <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
          <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
          <path d="m3 7l9 6l9-6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
