---
import { url } from '../utils/url'
---
<style>
  @keyframes blink {
    0%, 88%, 100% { transform: scaleY(1); }
    92%           { transform: scaleY(0.12); }
    96%           { transform: scaleY(1); }
  }
  .blink-face {
    display: inline-block;
    animation: blink 3.5s infinite;
    transform-origin: center 60%;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  .typewriter-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background: currentColor;
    margin-left: 2px;
    vertical-align: middle;
    animation: cursor-blink 0.75s step-start infinite;
  }
  .typewriter-cursor.typing {
    animation: none;
    opacity: 1;
  }


  /* Icon: Front-End code lines */
  @keyframes fe-grow {
    0%, 8%    { transform: scaleX(0); opacity: 0; }
    30%, 75%  { transform: scaleX(1); opacity: 1; }
    92%, 100% { transform: scaleX(0); opacity: 0; }
  }
  .fe-l1 { transform-box: fill-box; transform-origin: left center; animation: fe-grow 4s ease-in-out infinite; }
  .fe-l2 { transform-box: fill-box; transform-origin: left center; animation: fe-grow 4s ease-in-out 0.3s infinite; }
  .fe-l3 { transform-box: fill-box; transform-origin: left center; animation: fe-grow 4s ease-in-out 0.6s infinite; }
  .fe-l4 { transform-box: fill-box; transform-origin: left center; animation: fe-grow 4s ease-in-out 0.85s infinite; }
</style>
<section class="min-h-screen max-w-5xl mx-auto px-6 pt-20 pb-[60px] text-center flex flex-col">

  <!-- Block 1: Intro (~60%) -->
  <div class="flex-[3] flex flex-col justify-center">
    <h1 class="text-xl font-normal leading-tight mb-4" style='font-family: "Rubik", sans-serif'>
      <span id="typewriter-text"></span><span class="typewriter-cursor" id="typewriter-cursor"></span>
      <span class="text-[var(--color-accent)]">Babi</span>. <span class="blink-face">ツ</span>
    </h1>
    <p class="font-normal text-[#292d2e] leading-tight mb-4 w-[90%] mx-auto" style='font-size: 3rem; font-family: "EB Garamond", serif'>
      Designer who codes.<br>Developer who still cares about the details.
    </p>
    <p class="text-base text-[var(--color-muted)] leading-loose w-[70%] mx-auto">
      Not a designer who dabbles in code, or a developer with an eye for design. I do both seriously — and that's exactly where the interesting work lives.
    </p>
  </div>

  <!-- Block 2: Services + CTAs (~40%) -->
  <div class="flex-[2] flex flex-col justify-center">
    <div class="grid sm:grid-cols-3 gap-6 mb-12">
      <div>
        <!-- Product Design: artboard corner frame + curve + traveling dot -->
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="mb-5 mx-auto">
          <path d="M4 12 L4 4 L12 4" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M36 4 L44 4 L44 12" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4 36 L4 44 L12 44" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M36 44 L44 44 L44 36" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          <path id="icon-pd-path" d="M14 33 C18 22 20 15 24 21 C28 27 32 22 36 14"
                stroke="#FF5376" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          <circle r="3" fill="#FF5376">
            <animateMotion dur="3s" repeatCount="indefinite" calcMode="spline" keyTimes="0;1" keySplines="0.37 0 0.63 1">
              <mpath href="#icon-pd-path"/>
            </animateMotion>
          </circle>
        </svg>
        <h2 class="font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-2" style='font-size: 1rem; font-family: "Rubik", sans-serif; font-weight: 500'>Product Design</h2>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Research to Figma, designed with the build already in mind.</p>
      </div>
      <div>
        <!-- Front-End: browser window + animated code lines -->
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="mb-5 mx-auto">
          <rect x="3" y="7" width="42" height="34" rx="0" stroke="#292d2e" stroke-width="1.4"/>
          <line x1="3" y1="16" x2="45" y2="16" stroke="#292d2e" stroke-width="1.4"/>
          <circle cx="9" cy="11.5" r="1.5" fill="#e0ddd8"/>
          <circle cx="14.5" cy="11.5" r="1.5" fill="#e0ddd8"/>
          <rect x="9" y="22" width="24" height="2" rx="1" fill="#292d2e" class="fe-l1"/>
          <rect x="9" y="27" width="18" height="2" rx="1" fill="#292d2e" class="fe-l2"/>
          <rect x="9" y="32" width="10" height="2" rx="1" fill="#FF5376" class="fe-l3"/>
          <rect x="20" y="32" width="16" height="2" rx="1" fill="#292d2e" class="fe-l4"/>
        </svg>
        <h2 class="font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-2" style='font-size: 1rem; font-family: "Rubik", sans-serif; font-weight: 500'>Front-End Development</h2>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Interfaces that look right on every screen and work for every person using them.</p>
      </div>
      <div>
        <!-- End-to-end: 3-node pipeline + traveling dot -->
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="mb-5 mx-auto">
          <circle cx="6" cy="24" r="3.5" stroke="#292d2e" stroke-width="1.4" fill="#FAFAF8"/>
          <circle cx="24" cy="24" r="3.5" stroke="#292d2e" stroke-width="1.4" fill="#FAFAF8"/>
          <circle cx="42" cy="24" r="3.5" stroke="#292d2e" stroke-width="1.4" fill="#FAFAF8"/>
          <line x1="13" y1="24" x2="17" y2="24" stroke="#292d2e" stroke-width="1.4"/>
          <line x1="31" y1="24" x2="35.5" y2="24" stroke="#292d2e" stroke-width="1.4"/>
          <path d="M15 21.5 L17 24 L15 26.5" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M33.5 21.5 L35.5 24 L33.5 26.5" stroke="#292d2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path id="icon-ee-path" d="M6 24 L42 24" fill="none" stroke="none" visibility="hidden"/>
          <circle r="3.5" fill="#FF5376">
            <animateMotion dur="2.5s" repeatCount="indefinite" calcMode="linear">
              <mpath href="#icon-ee-path"/>
            </animateMotion>
          </circle>
        </svg>
        <h2 class="font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-2" style='font-size: 1rem; font-family: "Rubik", sans-serif; font-weight: 500'>End-to-end delivery</h2>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Figma to deployed — I own the whole path, so nothing gets lost in translation.</p>
      </div>
    </div>

    <div class="flex gap-4 flex-wrap items-center justify-center">
      <a
        href={url('work')}
        class="px-6 py-3 bg-[var(--color-text)] text-white text-sm font-medium tracking-wide hover:bg-[#333] transition-colors"
      >
        See projects
      </a>
      <a
        href="mailto:bacarolina.g@gmail.com"
        class="group flex items-center gap-2 px-6 py-3 border border-[var(--color-text)] text-sm font-medium tracking-wide hover:bg-[var(--color-text)] hover:text-white transition-colors"
      >
        Say hello
        <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
          <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
          <path d="m3 7l9 6l9-6"/>
        </svg>
      </a>
    </div>
  </div>

</section>

<script>
  const phrases = ["Hi, I'm", "Bonjour, je suis", "Olá, eu sou a"]
  const el = document.getElementById('typewriter-text')!
  const cursor = document.getElementById('typewriter-cursor')!

  const TYPE_SPEED = 80
  const DELETE_SPEED = 45
  const PAUSE_AFTER_TYPE = 2000
  const PAUSE_BEFORE_TYPE = 300

  let phraseIndex = 0
  let charIndex = 0
  let deleting = false

  function tick() {
    const phrase = phrases[phraseIndex]

    if (!deleting) {
      cursor.classList.add('typing')
      el.textContent = phrase.slice(0, ++charIndex)

      if (charIndex === phrase.length) {
        cursor.classList.remove('typing')
        deleting = true
        setTimeout(tick, PAUSE_AFTER_TYPE)
        return
      }
      setTimeout(tick, TYPE_SPEED)
    } else {
      cursor.classList.add('typing')
      el.textContent = phrase.slice(0, --charIndex)

      if (charIndex === 0) {
        deleting = false
        phraseIndex = (phraseIndex + 1) % phrases.length
        cursor.classList.remove('typing')
        setTimeout(tick, PAUSE_BEFORE_TYPE)
        return
      }
      setTimeout(tick, DELETE_SPEED)
    }
  }

  setTimeout(tick, 400)

</script>
