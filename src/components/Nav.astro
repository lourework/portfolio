---
import { url } from '../utils/url'
const pathname = Astro.url.pathname
const navLinks = [
  { href: url(''), label: 'home' },
  { href: url('work'), label: 'work' },
  { href: url('about'), label: 'about' },
]
---
<style>
  @keyframes blink {
    0%, 88%, 100% { transform: scaleY(1); }
    92%           { transform: scaleY(0.12); }
    96%           { transform: scaleY(1); }
  }
  .blink-face {
    display: inline-block;
    animation: blink 3.5s infinite;
    transform-origin: center 60%;
  }
</style>
<nav class="fixed top-0 left-0 right-0 z-50 bg-[#FBFBF2]/90 backdrop-blur-sm border-b border-[#e0ddd8]">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={url('')} class="font-serif text-lg font-semibold tracking-tight">
      <span class="text-[#E16F7C]">Babi</span>.
    </a>
    <ul class="flex gap-8 items-center">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`text-sm tracking-wide transition-colors ${
              pathname === href || (href !== '/' && pathname.startsWith(href))
                ? 'text-[#1a1a1a] font-medium'
                : 'text-[#2C363F] hover:text-[#E16F7C]'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://drive.google.com/file/d/1ulmNJgsgWb_F0uNBbFBwGC8nOPQ_4ghf/view?usp=sharing"
          target="_blank"
          rel="noopener"
          class="text-sm tracking-wide px-3 py-1.5 border border-[#1a1a1a] text-[#1a1a1a] hover:bg-[#1a1a1a] hover:text-white transition-colors"
        >
          resume ↗
        </a>
      </li>
    </ul>
  </div>
</nav>
<div class="h-16" />
