---
import FigmaEmbed from './FigmaEmbed.astro'
import type { ProjectStudy } from '../../data/projects/index'

interface Props {
  project: ProjectStudy
}

const { project: p } = Astro.props
import { url } from '../../utils/url'

const tocItems: { id: string; label: string }[] = []
if (p.overview) tocItems.push({ id: 'overview', label: 'Overview' })
if (p.goal) tocItems.push({ id: 'goal', label: 'Project Goal' })
if (p.personas && p.personas.length > 0) tocItems.push({ id: 'personas', label: 'Users & Personas' })
if (p.userContext && p.userContext.length > 0) tocItems.push({ id: 'user-context', label: 'User Context' })
if (p.research && p.research.length > 0) tocItems.push({ id: 'research', label: 'Research' })
if (p.solutionAlternatives) tocItems.push({ id: 'solution-alternatives', label: 'Solution Alternatives' })
if (p.solution) tocItems.push({ id: 'solution', label: 'Solution' })
if (p.wireframes) tocItems.push({ id: 'wireframes', label: 'Wireframes' })
if (p.usabilityTests && p.usabilityTests.length > 0) tocItems.push({ id: 'usability-tests', label: 'Usability Tests' })
if (p.prototype) tocItems.push({ id: 'prototype', label: 'Prototype' })
if (p.nextSteps) tocItems.push({ id: 'next-steps', label: 'Next Steps' })
---

<!-- Hero header -->
<header id="project-hero" class="max-w-5xl mx-auto px-6 mb-16 pt-6">
  <div class="flex gap-2 flex-wrap mb-4">
    {p.category.map(cat => (
      <span class="text-xs text-[#2C363F] uppercase tracking-widest border border-[#e0ddd8] px-2 py-1">{cat}</span>
    ))}
  </div>
  <h1 class="font-serif text-4xl sm:text-5xl font-semibold leading-tight">{p.title}</h1>
</header>

<!-- Sidebar -->
<aside id="project-sidebar" class="flex flex-col justify-between py-10 overflow-y-auto">

  <!-- Top: title → tags -->
  <div>
    <h2 class="font-serif text-base font-semibold leading-snug mb-3 text-[#1a1a1a]">{p.title}</h2>
    <div class="flex gap-1 flex-wrap mb-5">
      {p.category.map(cat => (
        <span class="text-[8px] text-[#2C363F] uppercase tracking-widest border border-[#e0ddd8] px-1.5 py-0.5">{cat}</span>
      ))}
    </div>
  </div>

  <!-- Bottom: Table of Contents -->
  <nav aria-label="Page sections" class="mt-10">
    <ul class="space-y-2">
      {tocItems.map(item => (
        <li class="text-right">
          <a
            href={`#${item.id}`}
            class="toc-link text-[11px] text-[#6b6b6b] hover:text-[#1a1a1a] transition-colors leading-snug"
            data-section={item.id}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<!-- Main content -->
<article class="max-w-5xl mx-auto px-6 pb-20">

  <!-- Cover -->
  {p.coverImage && (
    <div class="aspect-video overflow-hidden bg-[#eeecea] mb-16">
      <img src={url(p.coverImage.replace(/^\//, ''))} alt={p.title} class="w-full h-full object-cover" />
    </div>
  )}

  <!-- Overview -->
  {p.overview && (
    <section id="overview" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto">
        <p class="text-base leading-relaxed text-[#3a3a3a] whitespace-pre-line">{p.overview}</p>
      </div>
    </section>
  )}

  <!-- Goal -->
  {p.goal && (
    <section id="goal" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto">
        <h2 class="font-serif text-2xl font-semibold mb-4">Project Goal</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.goal}</p>
      </div>
    </section>
  )}

  <!-- Personas -->
  {p.personas && p.personas.length > 0 && (
    <section id="personas" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold">Users & Personas</h2>
      </div>
      {p.personas.length === 1 ? (
        <div style="width:90%;margin:0 auto;">
          <div class="bg-[#eeecea] overflow-hidden">
            <img src={url(p.personas[0].image.replace(/^\//, ''))} alt={p.personas[0].title} class="w-full object-cover" />
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {p.personas.map(persona => (
            <div class="bg-[#eeecea] overflow-hidden">
              <img src={url(persona.image.replace(/^\//, ''))} alt={persona.title} class="w-full object-cover" />
              <p class="text-sm font-medium p-4">{persona.title}</p>
            </div>
          ))}
        </div>
      )}
    </section>
  )}

  <!-- User Context -->
  {p.userContext && p.userContext.length > 0 && (
    <section id="user-context" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold">User Context</h2>
      </div>
      <div class="space-y-10">
        {p.userContext.map(ctx => (
          <div>
            <div class="w-4/5 mx-auto mb-4">
              <h3 class="font-serif text-lg font-semibold mb-2">{ctx.title}</h3>
              <p class="text-base leading-relaxed text-[#3a3a3a]">{ctx.description}</p>
            </div>
            {ctx.image && (
              <div class="bg-[#eeecea] overflow-hidden">
                <img src={url(ctx.image.replace(/^\//, ''))} alt={ctx.title} class="w-full object-cover" />
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Research -->
  {p.research && p.research.length > 0 && (
    <section id="research" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold">Research</h2>
      </div>
      <div class="space-y-10">
        {p.research.map(r => (
          <div>
            <div class="w-4/5 mx-auto mb-4">
              <h3 class="font-serif text-lg font-semibold mb-2">{r.title}</h3>
              <p class="text-base leading-relaxed text-[#3a3a3a]">{r.content}</p>
            </div>
            {r.image && (
              <div class="bg-[#eeecea] overflow-hidden">
                <img src={url(r.image.replace(/^\//, ''))} alt={r.title} class="w-full object-cover" />
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Solution Alternatives -->
  {p.solutionAlternatives && (
    <section id="solution-alternatives" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold mb-4">Solution Alternatives</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.solutionAlternatives.content}</p>
      </div>
      {p.solutionAlternatives.images.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {p.solutionAlternatives.images.map(img => (
            <div class="bg-[#eeecea] overflow-hidden">
              <img src={url(img.replace(/^\//, ''))} alt="Solution alternatives" class="w-full object-cover" />
            </div>
          ))}
        </div>
      )}
    </section>
  )}

  <!-- Solution -->
  {p.solution && (
    <section id="solution" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold mb-4">Solution</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.solution.concept}</p>
        {p.solution.branding && (
          <p class="text-base leading-relaxed text-[#3a3a3a] mt-4">{p.solution.branding}</p>
        )}
      </div>
      {p.solution.images.length > 0 && (
        <div class={`grid gap-4 ${p.solution.images.length === 1 ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {p.solution.images.map(img => (
            <div class="bg-[#eeecea] overflow-hidden">
              <img src={url(img.replace(/^\//, ''))} alt="Solution" class="w-full object-cover" />
            </div>
          ))}
        </div>
      )}
    </section>
  )}

  <!-- Wireframes -->
  {p.wireframes && (
    <section id="wireframes" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold mb-4">Wireframes</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.wireframes.description}</p>
      </div>
      {p.wireframes.images.length > 0 && (
        <div class={`grid gap-4 mb-6 ${p.wireframes.images.length === 1 ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {p.wireframes.images.map(img => (
            <div class="bg-[#eeecea] overflow-hidden">
              <img src={url(img.replace(/^\//, ''))} alt="Wireframes" class="w-full object-cover" />
            </div>
          ))}
        </div>
      )}
      {p.wireframes.figmaUrl && <FigmaEmbed url={p.wireframes.figmaUrl} title="Wireframe prototype" />}
    </section>
  )}

  <!-- Usability Tests -->
  {p.usabilityTests && p.usabilityTests.length > 0 && (
    <section id="usability-tests" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto">
        <h2 class="font-serif text-2xl font-semibold mb-4">Usability Tests</h2>
        <ul class="space-y-2">
          {p.usabilityTests.map(item => (
            <li class="flex gap-3 text-[#3a3a3a]"><span class="text-[#E16F7C] mt-1">→</span>{item}</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Prototype -->
  {p.prototype && (
    <section id="prototype" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto mb-6">
        <h2 class="font-serif text-2xl font-semibold mb-4">Prototype</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.prototype.description}</p>
      </div>
      {p.prototype.images.length > 0 && (
        <div class={`grid gap-4 mb-6 ${p.prototype.images.length === 1 ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {p.prototype.images.map(img => (
            <div class="bg-[#eeecea] overflow-hidden">
              <img src={url(img.replace(/^\//, ''))} alt="Prototype" class="w-full object-cover" />
            </div>
          ))}
        </div>
      )}
      {p.prototype.videoUrl && (
        p.prototype.videoUrl.includes('youtube') || p.prototype.videoUrl.includes('youtu.be')
          ? <div class="w-full aspect-video border border-[#e0ddd8] overflow-hidden mb-6"><iframe src={p.prototype.videoUrl} title="Video" allowfullscreen class="w-full h-full" loading="lazy" /></div>
          : <video src={p.prototype.videoUrl} controls class="w-full mb-6 border border-[#e0ddd8]" />
      )}
      {p.prototype.figmaUrl && <FigmaEmbed url={p.prototype.figmaUrl} title="Prototype" />}
    </section>
  )}

  <!-- Next Steps -->
  {p.nextSteps && (
    <section id="next-steps" class="mb-14 scroll-mt-24">
      <div class="w-4/5 mx-auto">
        <h2 class="font-serif text-2xl font-semibold mb-4">Next Steps</h2>
        <p class="text-base leading-relaxed text-[#3a3a3a]">{p.nextSteps}</p>
      </div>
    </section>
  )}

</article>

<style>
  #project-sidebar {
    display: none;
    position: fixed;
    top: 4rem;
    left: 1.5rem;
    width: calc(50% - 32rem - 1.5rem - 1rem);
    height: calc(100vh - 4rem);
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
    transition: clip-path 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (min-width: 1440px) {
    #project-sidebar {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
  }

  #project-sidebar.is-visible {
    clip-path: inset(0 0 0% 0);
    pointer-events: auto;
  }

  .toc-link.is-active {
    color: #1a1a1a;
    font-weight: 500;
  }
  .toc-link.is-active::before {
    content: '— ';
    color: #E16F7C;
  }
</style>

<script>
  const sidebar = document.getElementById('project-sidebar')
  const hero = document.getElementById('project-hero')
  const boundary = document.getElementById('project-nav')

  function clampSidebar() {
    if (!sidebar || !boundary) return
    const boundaryTop = boundary.getBoundingClientRect().top
    const navHeight = 64
    if (boundaryTop < window.innerHeight) {
      sidebar.style.height = `${Math.max(0, boundaryTop - navHeight)}px`
    } else {
      sidebar.style.height = 'calc(100vh - 4rem)'
    }
  }

  if (sidebar && hero) {
    const heroObserver = new IntersectionObserver(
      ([entry]) => {
        sidebar.classList.toggle('is-visible', !entry.isIntersecting)
      },
      { threshold: 0 }
    )
    heroObserver.observe(hero)
  }

  window.addEventListener('scroll', clampSidebar, { passive: true })
  clampSidebar()

  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
  const sections = document.querySelectorAll<HTMLElement>('section[id]')

  const setActive = (id: string) => {
    links.forEach(l => l.classList.remove('is-active'))
    const active = document.querySelector<HTMLAnchorElement>(`.toc-link[data-section="${id}"]`)
    active?.classList.add('is-active')
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) setActive(entry.target.id)
      })
    },
    { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
  )

  sections.forEach(s => observer.observe(s))
</script>
