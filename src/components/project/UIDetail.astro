---
import FigmaEmbed from './FigmaEmbed.astro'
import ImageGallery from '../ImageGallery'
import type { ProjectUI } from '../../data/projects/index'

interface Props {
  project: ProjectUI
}

const { project: p } = Astro.props
import { url } from '../../utils/url'
---
<article class="max-w-5xl mx-auto px-6 pb-20">
  <header class="mb-16 pt-6">
    <div class="flex gap-2 flex-wrap mb-4">
      {p.category.map(cat => (
        <span class="text-xs text-[var(--color-muted)] uppercase tracking-widest border border-[var(--color-border)] px-2 py-1">{cat}</span>
      ))}
    </div>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold leading-tight mb-4">{p.title}</h1>
    {p.contextNote && (
      <p class="text-sm text-[var(--color-muted)] italic">{p.contextNote}</p>
    )}
  </header>

  {p.coverImage && !p.hideCoverInDetail && (
    <div class="aspect-video overflow-hidden bg-[#eeecea] mb-16">
      <img src={url(p.coverImage.replace(/^\//, ''))} alt={p.title} class="w-full h-full object-cover" />
    </div>
  )}

  <div class="space-y-20">
    {p.groups.map(group => (
      <section>
        <h2 class="font-serif text-2xl font-semibold mb-3">{group.title}</h2>
        {group.description && (
          <p class="text-base leading-relaxed text-[#3a3a3a] mb-6">{group.description}</p>
        )}
        {group.images.length === 1 && (
          <div style="width:90%;margin:40px auto 32px;">
            <img src={url(group.images[0].replace(/^\//, ''))} alt={group.title} style="width:100%;height:auto;display:block;" />
          </div>
        )}
        {group.images.length > 1 && (
          <ImageGallery
            client:load
            images={group.images.map(img => url(img.replace(/^\//, '')))}
            alt={group.title}
          />
        )}
        {group.figmaUrl && <FigmaEmbed url={group.figmaUrl} title={group.title} />}
      </section>
    ))}
  </div>
</article>
