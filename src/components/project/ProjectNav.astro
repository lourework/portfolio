---
import { allProjects } from '../../data/projects/index'
import { url } from '../../utils/url'

interface Props {
  currentSlug: string
}

const { currentSlug } = Astro.props
const idx = allProjects.findIndex(p => p.slug === currentSlug)
const prev = idx > 0 ? allProjects[idx - 1] : null
const next = idx < allProjects.length - 1 ? allProjects[idx + 1] : null
---
<div id="project-nav" class="max-w-5xl mx-auto px-6 py-16 mt-8 border-t border-[var(--color-border)] flex justify-between gap-8">
  {prev ? (
    <a href={url(`work/${prev.slug}`)} class="group max-w-xs">
      <span class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1 block">← Previous</span>
      <span class="font-serif text-base font-semibold group-hover:text-[var(--color-accent)] transition-colors">{prev.title}</span>
    </a>
  ) : <div />}
  {next ? (
    <a href={url(`work/${next.slug}`)} class="group max-w-xs text-right ml-auto">
      <span class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1 block">Next →</span>
      <span class="font-serif text-base font-semibold group-hover:text-[var(--color-accent)] transition-colors">{next.title}</span>
    </a>
  ) : <div />}
</div>
