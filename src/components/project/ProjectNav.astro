---
import { allProjects } from '../../data/projects/index'

interface Props {
  currentSlug: string
}

const { currentSlug } = Astro.props
const idx = allProjects.findIndex(p => p.slug === currentSlug)
const prev = idx > 0 ? allProjects[idx - 1] : null
const next = idx < allProjects.length - 1 ? allProjects[idx + 1] : null
---
<nav class="max-w-5xl mx-auto px-6 pt-8 pb-4">
  <a href="/work" class="inline-flex items-center gap-2 text-sm text-[#2C363F] hover:text-[#1a1a1a] transition-colors mb-10 group">
    <span class="group-hover:-translate-x-1 transition-transform">←</span>
    Back to work
  </a>
</nav>

<div class="max-w-5xl mx-auto px-6 py-16 mt-16 border-t border-[#e0ddd8] flex justify-between gap-8">
  {prev ? (
    <a href={`/work/${prev.slug}`} class="group max-w-xs">
      <span class="text-xs text-[#2C363F] uppercase tracking-widest mb-1 block">← Previous</span>
      <span class="font-serif text-base font-semibold group-hover:text-[#E16F7C] transition-colors">{prev.title}</span>
    </a>
  ) : <div />}
  {next ? (
    <a href={`/work/${next.slug}`} class="group max-w-xs text-right ml-auto">
      <span class="text-xs text-[#2C363F] uppercase tracking-widest mb-1 block">Next →</span>
      <span class="font-serif text-base font-semibold group-hover:text-[#E16F7C] transition-colors">{next.title}</span>
    </a>
  ) : <div />}
</div>
