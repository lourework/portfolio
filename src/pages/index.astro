---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ProjectGrid from '../components/ProjectGrid.astro'
import Contact from '../components/Contact.astro'
import { allProjects } from '../data/projects/index'

const featured = allProjects.filter(p => p.featured)
---
<BaseLayout>
  <Hero />

  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-[#e0ddd8]">
    <div class="flex items-baseline justify-between mb-12">
      <h2 class="font-serif text-3xl font-semibold">Selected work</h2>
      <a href="/work" class="text-sm text-[#2C363F] hover:text-[#E16F7C] transition-colors">
        View all →
      </a>
    </div>
    <ProjectGrid projects={featured} />
  </section>

  <Contact />
</BaseLayout>
